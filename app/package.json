{
  "name": "routeai-eda",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "https://github.com/Guiimartinho/routeai",
  "author": {
    "name": "RouteAI Team",
    "email": "contact@routeai.dev"
  },
  "description": "LLM-Powered Electronic Design Automation Platform for PCB Design",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Guiimartinho/routeai.git"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --host 0.0.0.0 --port 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder --config electron/build-config.cjs",
    "electron:pack": "vite build && electron-builder --dir --config electron/build-config.cjs",
    "electron:build:win": "vite build && electron-builder --win --config electron/build-config.cjs",
    "electron:build:linux": "vite build && electron-builder --linux --config electron/build-config.cjs"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.0",
    "@react-three/drei": "^9.105.0",
    "@react-three/fiber": "^8.16.0",
    "isomorphic-git": "^1.27.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.164.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "svg2pdf.js": "^2.2.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "extends": "./electron/build-config.cjs"
  }
}
